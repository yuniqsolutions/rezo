{
  "name": "rezo",
  "version": "1.0.131",
  "description": "Lightning-fast, enterprise-grade HTTP client for modern JavaScript. Full HTTP/2 support, intelligent cookie management, multiple adapters (HTTP, Fetch, cURL, XHR), streaming, proxy support (HTTP/HTTPS/SOCKS), and cross-environment compatibility.",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "sideEffects": false,
  "author": "Olajide Mathew Ogundare <git@yuniq.solutions>",
  "company": "Yuniq Solutions Tech",
  "license": "MIT",
  "keywords": [
    "http",
    "http2",
    "https",
    "http-client",
    "request",
    "response",
    "fetch",
    "curl",
    "xhr",
    "typescript",
    "cookies",
    "cookie-jar",
    "web-scraping",
    "crawler",
    "scraper",
    "nodejs",
    "node",
    "browser",
    "bun",
    "deno",
    "edge-runtime",
    "cloudflare-workers",
    "react-native",
    "streaming",
    "proxy",
    "socks",
    "socks5",
    "download",
    "upload",
    "progress",
    "interceptors",
    "hooks",
    "adapters",
    "retry",
    "timeout",
    "enterprise",
    "production-ready"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/yuniqsolutions/rezo.git"
  },
  "bugs": {
    "url": "https://github.com/yuniqsolutions/rezo/issues"
  },
  "homepage": "https://github.com/yuniqsolutions/rezo#readme",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "tough-cookie": "^6.0.1",
    "ua-parser-js": "^2.0.9"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@react-native-community/netinfo": "^12.0.1",
    "@types/bun": "^1.3.11",
    "@types/deno": "^2.5.0",
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^4.1.2",
    "dts-bundle-generator": "^9.5.1",
    "eslint": "^10.2.0",
    "expo-background-task": "^55.0.12",
    "expo-file-system": "^55.0.14",
    "expo-task-manager": "^55.0.12",
    "postcss-value-parser": "^4.2.0",
    "puppeteer": "^24.40.0",
    "react-native-fs": "^2.20.0",
    "tsx": "^4.21.0",
    "typescript": "5.9.2",
    "vitest": "^4.1.2"
  },
  "typesVersions": {
    "*": {
      "platform/node": [
        "dist/platform/node.d.ts"
      ],
      "platform/browser": [
        "dist/platform/browser.d.ts"
      ],
      "platform/bun": [
        "dist/platform/bun.d.ts"
      ],
      "platform/deno": [
        "dist/platform/deno.d.ts"
      ],
      "platform/worker": [
        "dist/platform/worker.d.ts"
      ],
      "platform/react-native": [
        "dist/platform/react-native.d.ts"
      ],
      "adapters/http": [
        "dist/adapters/entries/http.d.ts"
      ],
      "adapters/http2": [
        "dist/adapters/entries/http2.d.ts"
      ],
      "adapters/curl": [
        "dist/adapters/entries/curl.d.ts"
      ],
      "adapters/fetch": [
        "dist/adapters/entries/fetch.d.ts"
      ],
      "adapters/xhr": [
        "dist/adapters/entries/xhr.d.ts"
      ],
      "adapters/react-native": [
        "dist/adapters/entries/react-native.d.ts"
      ],
      "crawler": [
        "dist/crawler.d.ts"
      ],
      "wget": [
        "dist/wget/index.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "deno": "./dist/index.js",
      "bun": "./dist/index.js",
      "react-native": {
        "types": "./dist/platform/react-native.d.ts",
        "require": "./dist/platform/react-native.cjs",
        "default": "./dist/platform/react-native.js"
      },
      "browser": {
        "types": "./dist/platform/browser.d.ts",
        "require": "./dist/platform/browser.cjs",
        "default": "./dist/platform/browser.js"
      },
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./platform/node": {
      "types": "./dist/platform/node.d.ts",
      "import": "./dist/platform/node.js",
      "require": "./dist/platform/node.cjs"
    },
    "./platform/browser": {
      "types": "./dist/platform/browser.d.ts",
      "import": "./dist/platform/browser.js",
      "require": "./dist/platform/browser.cjs"
    },
    "./platform/bun": {
      "types": "./dist/platform/bun.d.ts",
      "import": "./dist/platform/bun.js",
      "require": "./dist/platform/bun.cjs"
    },
    "./platform/deno": {
      "types": "./dist/platform/deno.d.ts",
      "import": "./dist/platform/deno.js",
      "require": "./dist/platform/deno.cjs"
    },
    "./platform/worker": {
      "types": "./dist/platform/worker.d.ts",
      "import": "./dist/platform/worker.js",
      "require": "./dist/platform/worker.cjs"
    },
    "./platform/react-native": {
      "types": "./dist/platform/react-native.d.ts",
      "import": "./dist/platform/react-native.js",
      "require": "./dist/platform/react-native.cjs"
    },
    "./adapters/http": {
      "types": "./dist/adapters/entries/http.d.ts",
      "import": "./dist/adapters/entries/http.js",
      "require": "./dist/adapters/entries/http.cjs"
    },
    "./adapters/http2": {
      "types": "./dist/adapters/entries/http2.d.ts",
      "import": "./dist/adapters/entries/http2.js",
      "require": "./dist/adapters/entries/http2.cjs"
    },
    "./adapters/curl": {
      "types": "./dist/adapters/entries/curl.d.ts",
      "import": "./dist/adapters/entries/curl.js",
      "require": "./dist/adapters/entries/curl.cjs"
    },
    "./adapters/fetch": {
      "types": "./dist/adapters/entries/fetch.d.ts",
      "import": "./dist/adapters/entries/fetch.js",
      "require": "./dist/adapters/entries/fetch.cjs"
    },
    "./adapters/xhr": {
      "types": "./dist/adapters/entries/xhr.d.ts",
      "import": "./dist/adapters/entries/xhr.js",
      "require": "./dist/adapters/entries/xhr.cjs"
    },
    "./adapters/react-native": {
      "types": "./dist/adapters/entries/react-native.d.ts",
      "import": "./dist/adapters/entries/react-native.js",
      "require": "./dist/adapters/entries/react-native.cjs"
    },
    "./crawler": {
      "types": "./dist/crawler.d.ts",
      "import": "./dist/entries/crawler.js",
      "require": "./dist/entries/crawler.cjs"
    },
    "./wget": {
      "types": "./dist/wget/index.d.ts",
      "import": "./dist/wget/index.js",
      "require": "./dist/wget/index.cjs"
    }
  },
  "browser": {
    "./dist/platform/node.js": "./dist/platform/browser.js",
    "./dist/platform/node.cjs": "./dist/platform/browser.cjs",
    "./dist/adapters/http.js": "./dist/adapters/fetch.js",
    "./dist/adapters/http.cjs": "./dist/adapters/fetch.cjs",
    "./dist/utils/cookies.js": "./dist/utils/cookies.browser.js",
    "./dist/utils/cookies.cjs": "./dist/utils/cookies.browser.cjs",
    "./dist/cache/response-cache.js": "./dist/cache/universal-response-cache.js",
    "./dist/cache/response-cache.cjs": "./dist/cache/universal-response-cache.cjs"
  },
  "peerDependencies": {
    "linkedom": ">=0.16.0"
  },
  "peerDependenciesMeta": {
    "linkedom": {
      "optional": true
    }
  },
  "react-native": {
    "./dist/platform/node.js": "./dist/platform/react-native.js",
    "./dist/platform/node.cjs": "./dist/platform/react-native.cjs",
    "./dist/adapters/http.js": "./dist/adapters/react-native.js",
    "./dist/utils/cookies.js": "./dist/utils/cookies.browser.js",
    "./dist/utils/cookies.cjs": "./dist/utils/cookies.browser.cjs",
    "./dist/cache/response-cache.js": "./dist/cache/universal-response-cache.js",
    "./dist/cache/response-cache.cjs": "./dist/cache/universal-response-cache.cjs"
  },
  "files": [
    "dist/**/*",
    "assets/**/*",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}